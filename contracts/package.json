{
  "name": "@driftgate/contracts",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared DriftGate canonical schemas and contracts.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "COMPATIBILITY_POLICY.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/driftgate/driftgate-sdk.git"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node20 --dts --sourcemap --clean --tsconfig tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}
